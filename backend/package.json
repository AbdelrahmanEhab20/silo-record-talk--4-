    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.3",
    "multer": "^1.4.5-lts.1",
    "resend": "^4.8.0"
  },
  "devDependencies": {
    "eslint": "^9.26.0",
    "nodemon": "^3.1.10"
  }
}
