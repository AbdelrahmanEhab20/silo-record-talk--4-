{
  "name": "silo-backend",
  "version": "0.1.0",
  "description": "Owned backend for Silo (Render + MongoDB)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js src/server.js",
    "start": "node src/server.js",
    "worker": "node src/worker.js",
